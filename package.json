{
  "name": "useful-codemods",
  "private": true,
  "description": "Useful codemods made by Codemod.",
  "workspaces": [
    "codemods/*",
    "codemods/*/*"
  ],
  "scripts": {
    "test": "yarn workspaces foreach -A run test",
    "check-types": "yarn workspaces foreach -A run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version && bash scripts/sync-codemod-versions.sh"
  },
  "packageManager": "yarn@4.9.1",
  "devDependencies": {
    "@changesets/cli": "^2.30.0"
  }
}
