{
  "name": "useful-codemods",
  "private": true,
  "description": "Useful codemods made by Backstage.",
  "workspaces": [
    "codemods/*",
    "codemods/*/*"
  ],
  "scripts": {
    "test": "yarn workspaces foreach -A run test",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-aware --type-check --deny-warnings --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --type-aware --type-check --fix --no-error-on-unmatched-pattern",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version && bash scripts/sync-codemod-versions.sh",
    "readme": "bash scripts/generate-readme-codemods.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "yarn@4.14.1"
}
